"""
Question 11: 0-1 Knapsack Problem using Dynamic Programming
- Each item can be taken (1) or not taken (0) — no fractions.
- DP table: dp[i][w] = max value using first i items with capacity w.
- Time complexity : O(n × W)
- Space complexity: O(n × W)
- Includes backtracking to identify which items are selected.
"""


# ──────────────────────────────────────────────
# 0-1 KNAPSACK (DYNAMIC PROGRAMMING)
# ──────────────────────────────────────────────

def knapsack_01(weights, values, capacity):
    """
    Solve the 0-1 Knapsack problem using Dynamic Programming.

    Parameters:
        weights  : list of item weights  [w1, w2, ..., wn]
        values   : list of item values   [v1, v2, ..., vn]
        capacity : maximum weight the knapsack can carry

    Returns:
        max_value : maximum total value achievable
        selected  : indices of items selected (0-based)
        dp        : the full DP table (for display)
    """
    n = len(weights)

    # Build DP table
    # dp[i][w] = best value with first i items and capacity w
    dp = [[0] * (capacity + 1) for _ in range(n + 1)]

    for i in range(1, n + 1):
        for w in range(capacity + 1):
            # Option 1: Don't take item i
            dp[i][w] = dp[i - 1][w]
            # Option 2: Take item i (only if it fits)
            if weights[i - 1] <= w:
                take_value = dp[i - 1][w - weights[i - 1]] + values[i - 1]
                if take_value > dp[i][w]:
                    dp[i][w] = take_value

    max_value = dp[n][capacity]

    # Backtrack to find which items were selected
    selected = []
    w = capacity
    for i in range(n, 0, -1):
        if dp[i][w] != dp[i - 1][w]:
            selected.append(i - 1)      # item index (0-based)
            w -= weights[i - 1]

    selected.reverse()
    return max_value, selected, dp


def print_dp_table(dp, n, capacity, weights, values):
    """Print the DP table in a readable grid format."""
    print(f"\n  DP Table  (rows = items 0..{n}, cols = capacity 0..{min(capacity,20)})")
    print(f"  (showing capacity up to {min(capacity, 20)} for readability)\n")

    cap_show = min(capacity, 20)

    # Header
    header = f"  {'i\\w':>5} |"
    for w in range(cap_show + 1):
        header += f"{w:>4}"
    print(header)
    print("  " + "─" * (7 + 4 * (cap_show + 1)))

    # Item labels
    labels = ["(none)"] + [f"i{i}(w={weights[i-1]},v={values[i-1]})" for i in range(1, n + 1)]

    for i in range(n + 1):
        row = f"  {labels[i]:>5} |" if i == 0 else f"  {labels[i]:>5} |"
        row = f"  {i:>5} |"
        for w in range(cap_show + 1):
            row += f"{dp[i][w]:>4}"
        print(row)


