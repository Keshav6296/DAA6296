# --- Example 1 ---
print("\n--- Example 1 ---")
weights1  = [2, 3, 4, 5]
values1   = [3, 4, 5, 6]
capacity1 = 8

print(f"  Items     : {list(zip(weights1, values1))}  (weight, value)")
print(f"  Capacity  : {capacity1}")

max_val1, selected1, dp1 = knapsack_01(weights1, values1, capacity1)

print(f"\n  Max Value : {max_val1}")
print(f"  Selected item indices (0-based): {selected1}")
print(f"  Selected items detail:")
total_w = total_v = 0
for idx in selected1:
    print(f"    Item {idx}: weight={weights1[idx]}, value={values1[idx]}")
    total_w += weights1[idx]
    total_v += values1[idx]
print(f"  Total weight used: {total_w} / {capacity1}")
print(f"  Total value      : {total_v}")

print_dp_table(dp1, len(weights1), capacity1, weights1, values1)

