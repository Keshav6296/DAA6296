"""
Question 10: Dijkstra's Shortest Path Algorithm
- Finds shortest distances from a given source node to all other nodes.
- Uses a min-heap priority queue: O((V + E) log V).
- Displays distances and reconstructed paths.
"""

import heapq


# ──────────────────────────────────────────────
# DIJKSTRA'S ALGORITHM
# ──────────────────────────────────────────────

def dijkstra(graph, source):
    """
    Find shortest paths from `source` to all reachable nodes.

    Parameters:
        graph  : dict  {node: [(neighbor, weight), ...]}
        source : the starting node

    Returns:
        dist : dict  {node: shortest_distance_from_source}
        prev : dict  {node: previous_node_in_shortest_path}
    """
    # Initialize distances as infinity
    dist = {node: float('inf') for node in graph}
    prev = {node: None for node in graph}
    dist[source] = 0

    # Min-heap: (distance, node)
    min_heap = [(0, source)]

    visited = set()

    while min_heap:
        d, u = heapq.heappop(min_heap)

        if u in visited:
            continue
        visited.add(u)

        for v, weight in graph.get(u, []):
            alt = dist[u] + weight
            if alt < dist[v]:
                dist[v] = alt
                prev[v] = u
                heapq.heappush(min_heap, (alt, v))

    return dist, prev


def reconstruct_path(prev, source, target):
    """Reconstruct the shortest path from source to target using prev map."""
    path = []
    node = target
    while node is not None:
        path.append(node)
        node = prev[node]
    path.reverse()
    if path[0] == source:
        return path
    return []   # No path exists


def print_all_paths(graph, source):
    """Run Dijkstra and print shortest distances + paths to all nodes."""
    dist, prev = dijkstra(graph, source)

    print(f"\n  Shortest paths from source: '{source}'")
    print(f"\n  {'Destination':<14} {'Distance':<12} {'Path'}")
    print(f"  {'─'*55}")

    for node in sorted(dist.keys(), key=str):
        if node == source:
            continue
        d = dist[node]
        if d == float('inf'):
            print(f"  {str(node):<14} {'∞':<12} No path")
        else:
            path = reconstruct_path(prev, source, node)
            path_str = " → ".join(str(p) for p in path)
            print(f"  {str(node):<14} {d:<12} {path_str}")

    return dist, prev


