class DebugDijkstra:
    def run(self, graph, source):
        dist = {node: float('inf') for node in graph}
        prev = {node: None for node in graph}
        dist[source] = 0
        heap = [(0, source)]
        visited = set()
        step = 1

        print(f"\n  {'Step':<6} {'Node':<8} {'Dist':<8} {'Via':<8} {'Updated Nodes'}")
        print(f"  {'─'*55}")

        while heap:
            d, u = heapq.heappop(heap)
            if u in visited:
                continue
            visited.add(u)
            updates = []
            for v, w in graph.get(u, []):
                alt = dist[u] + w
                if alt < dist[v]:
                    dist[v] = alt
                    prev[v] = u
                    heapq.heappush(heap, (alt, v))
                    updates.append(f"{v}={alt}")
            print(f"  {step:<6} {str(u):<8} {d:<8} {str(prev[u]):<8} {', '.join(updates) if updates else '—'}")
            step += 1

        return dist, prev

DebugDijkstra().run(graph1, 'A')
